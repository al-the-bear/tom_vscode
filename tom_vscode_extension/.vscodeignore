# Source files (compiled to out/). `**/*.ts` also covers `*.d.ts`; we ship no
# `.d.ts` at runtime (the only own one is the dev-only media/types shim below),
# so there is intentionally no `!**/*.d.ts` re-include.
src/**
**/*.ts

# Build config
tsconfig.json
tsconfig.media.json
.vscode/**

# Development files
_copilot_guidelines/**
doc/**
!doc/quick_reference.md
!doc/workspace_setup.md
example/**
.npmrc

# Webview media dev-only types (the runtime media assets DO ship; the ambient
# typecheck shims under media/types/ are dev-only — exclude them even though the
# global !**/*.d.ts re-include rule above would otherwise pull them in).
media/types/**

# Test files
**/*.test.js
