{
  "//": "Typecheck for externalized webview JS (media/**). checkJs, no emit. Runs in the browser/webview sandbox — DOM libs, no Node/vscode host types.",
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": []
  },
  "include": ["media/**/*.js", "media/types/**/*.d.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
